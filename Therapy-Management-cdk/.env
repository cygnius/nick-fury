# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key
JWT_EXPIRES_IN=24h

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=your_aws_region

# Database Tables
USERS_TABLE=users_table_name
CLIENTS_TABLE=clients_table_name
THERAPISTS_TABLE=therapists_table_name
MAPPING_TABLE=mapping_table_name
JOURNAL_TABLE=journal_table_name
SESSION_TABLE=session_table_name
NOTES_TABLE=notes_table_name
MESSAGES_TABLE=messages_table_name